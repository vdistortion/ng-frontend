{
  "name": "ng-frontend",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "nx serve --host 0.0.0.0",
    "build": "nx build --base-href /ng-frontend/ && cd dist/browser && cp index.html 404.html",
    "watch": "nx build --watch --configuration development",
    "test": "nx test",
    "format": "prettier . --write",
    "public:gh": "gh-pages -d dist/browser",
    "public": "npm run build && npm run public:gh"
  },
  "license": "GPL",
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.9",
    "@angular-devkit/core": "^18.2.9",
    "@angular-devkit/schematics": "^18.2.9",
    "@angular/cli": "^18.2.9",
    "@angular/compiler-cli": "^18.2.0",
    "@nx/angular": "20.0.3",
    "@nx/workspace": "20.0.3",
    "@schematics/angular": "^18.2.9",
    "@types/jasmine": "~5.1.0",
    "gh-pages": "^6.2.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nx": "20.0.3",
    "prettier": "3.3.3",
    "typescript": "~5.5.2"
  }
}
